# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# OpenRouter (recommended — cheap Gemini models)
OPENROUTER_API_KEY=your_openrouter_key_here

# Or direct Google Gemini API
# GEMINI_API_KEY=your_gemini_key_here

# Optional model overrides
# OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_TEXT_MODEL=google/gemini-2.0-flash-lite-001
# OPENROUTER_CREATIVE_MODEL=google/gemini-2.0-flash-001

# Admin article log (/admin) — comma-separated emails allowed to view
ADMIN_EMAILS=admin@sikhomode.org

# One-time: create/update admin user in Supabase (never commit real passwords)
# ADMIN_BOOTSTRAP_PASSWORD=your_secure_password
# node scripts/ensure-admin-user.mjs

# Local dev
NEXT_PUBLIC_APP_URL=http://localhost:3003

# Vercel production (optional — defaults to https://wikime.online on Vercel if unset):
# NEXT_PUBLIC_APP_URL=https://wikime.online
#
# Required on Vercel for saving/sharing articles (file storage does not persist on serverless):
# NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
# OPENROUTER_API_KEY
#
# Supabase Auth → URL Configuration: add your Vercel URL and
# https://your-app.vercel.app/auth/callback to redirect allow list
